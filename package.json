{
  "name": "forkekan-mint",
  "version": "0.1.0",
  "private": true,
  "description": "Forkekan-mint — Anti Video Burik. \"4K kan min!\"",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @forkekan/api db:generate",
    "db:migrate": "pnpm --filter @forkekan/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @forkekan/api db:migrate:deploy",
    "db:seed": "pnpm --filter @forkekan/api db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4"
  }
}
