{
  "name": "@forkekan/web",
  "version": "0.1.0",
  "private": true,
  "description": "Forkekan-mint Frontend — React + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
