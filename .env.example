# ============================================
# Forkekan-mint — Environment Variables
# Salin file ini menjadi .env lalu isi nilainya.
# .env tidak pernah di-commit.
# ============================================

# Application
APP_NAME=Forkekan-mint
NODE_ENV=development

# Web (React + Vite)
WEB_PORT=3000
VITE_API_URL=http://localhost:4000/api/v1
VITE_GOOGLE_CLIENT_ID=

# API (NestJS)
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
# Base URL publik API — dipakai membangun signed download URL
API_PUBLIC_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://forkekan:forkekan@localhost:5432/forkekan_mint?schema=public
# Dipakai infra/compose/docker-compose.prod.yml untuk menyusun DATABASE_URL container
POSTGRES_USER=forkekan
POSTGRES_PASSWORD=forkekan
POSTGRES_DB=forkekan_mint

# Redis (Queue & Cache)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Cloudflare R2 (placeholder)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# FFmpeg (worker) — kosongkan untuk memakai binary dari PATH
FFMPEG_PATH=
FFPROBE_PATH=

# Local storage (relatif terhadap apps/api saat development)
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/outputs

# Rate limiting (opsional — default 120 request/60 detik per IP bila kosong)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
