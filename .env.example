# ============================================
# Forkekan-mint — Environment Variables
# Salin file ini menjadi .env lalu isi nilainya.
# .env tidak pernah di-commit.
# ============================================

# Application
APP_NAME=Forkekan-mint
NODE_ENV=development

# Web (React + Vite)
WEB_PORT=3000
VITE_API_URL=http://localhost:4000/api/v1
VITE_GOOGLE_CLIENT_ID=

# API (NestJS)
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://forkekan:forkekan@localhost:5432/forkekan_mint?schema=public

# Redis (Queue & Cache)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Cloudflare R2 (placeholder)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# FFmpeg (worker) — kosongkan untuk memakai ffmpeg dari PATH
FFMPEG_PATH=
